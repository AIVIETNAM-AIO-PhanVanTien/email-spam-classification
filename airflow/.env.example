# Airflow 3.x secrets — copy to airflow/.env and fill in.
# Generate one-liners:
#   AIRFLOW_FERNET_KEY:  python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
#   AIRFLOW_SECRET_KEY:  python -c 'import secrets; print(secrets.token_hex(32))'
#   AIRFLOW_JWT_SECRET:  python -c 'import secrets; print(secrets.token_hex(32))'
#
# Run from the repo root (compose reads .env from CWD):
#   docker compose --env-file airflow/.env -f airflow/docker-compose.yml up airflow-init
#   docker compose --env-file airflow/.env -f airflow/docker-compose.yml up -d

AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=
AIRFLOW_JWT_SECRET=

# Where the project code lives INSIDE the container. DAGs use this to call
# `python -m src.pipelines.monthly_run --month {{ ... }}` portably.
EMAIL_SPAM_PROJECT_DIR=/opt/airflow

# Noop on Docker (system Python already has deps); on EC2 this would be
# `source $EMAIL_SPAM_PROJECT_DIR/.venv/bin/activate`.
EMAIL_SPAM_VENV_ACT=true

# Where the champion pkl is written. Must be on a host-mounted volume so the
# FastAPI container (in the serving stack) sees the same file.
EMAIL_SPAM_MODEL_DIR=/opt/airflow/models

# FastAPI's /admin/reload-model endpoint. From inside the Airflow container the
# FastAPI service is reachable via the docker host bridge.
EMAIL_SPAM_API_RELOAD_URL=http://host.docker.internal:8000/admin/reload-model

# Optional knobs (defaults in src/pipelines/monthly_run.py).
DRIFT_SCORE_THRESHOLD=0.25
PROMOTION_F1_DELTA=0.0
TARGET_PRECISION=0.99
